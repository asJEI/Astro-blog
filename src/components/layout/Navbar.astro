---
import { getCollection } from "astro:content";

import siteIcon from "../../assets/site-icon.png";
import { sortPostsByDateDesc } from "../../lib/blog";

const navItems = [
  { label: "首页", href: "/" },
  { label: "所有文章", href: "/blog" },
  { label: "技术", href: "/blog/tech" },
  { label: "生活", href: "/blog/life" },
  { label: "幽微", href: "/blog/moments" },
  { label: "关于", href: "/about" },
];

const searchPosts = sortPostsByDateDesc(await getCollection("blog", ({ data }) => !data.draft)).map((post) => ({
  title: post.data.title,
  description: post.data.description ?? "",
  tags: post.data.tags,
  href: `/blog/${post.id}/`,
}));

const actionClass =
  "relative flex h-10 w-10 items-center justify-center rounded-card text-white/70 transition duration-200 hover:-translate-y-px hover:bg-white/10 hover:text-white";
---

<header class="fixed inset-x-0 top-0 z-50 px-4 py-4 text-white" data-navbar>
  <nav
    class="mx-auto grid min-h-14 w-full max-w-6xl grid-cols-[1fr_auto] items-center gap-4 rounded-[1.25rem] border border-white/12 bg-slate-950/28 p-2 shadow-[0_18px_48px_rgb(0_0_0_/_0.18)] backdrop-blur-2xl md:grid-cols-[1fr_auto_1fr]"
    aria-label="Primary navigation"
  >
    <a class="flex items-center gap-2 pl-1 no-underline" href="/" aria-label="北海首页">
      <img class="h-8 w-8 rounded-full object-cover" src={siteIcon.src} alt="" width="32" height="32" />
      <span class="text-base font-semibold tracking-[-0.03em]">北海</span>
    </a>

    <div class="hidden items-center gap-1 md:flex" aria-label="Main links">
      {
        navItems.map((item) => (
          <a
            class="relative rounded-card px-3 py-2 text-sm font-medium text-white/74 no-underline transition duration-200 after:absolute after:inset-x-3 after:bottom-1 after:h-px after:scale-x-75 after:bg-current after:opacity-0 after:transition after:duration-200 hover:-translate-y-px hover:bg-white/9 hover:text-white hover:after:scale-x-100 hover:after:opacity-32"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex justify-end gap-1">
      <button class={actionClass} type="button" aria-label="搜索" data-search-toggle>
        <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="m21 21-4.35-4.35m1.35-5.65a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
          />
        </svg>
      </button>

      <button class={actionClass} type="button" aria-label="切换暗黑模式" data-theme-toggle>
        <svg class="h-4 w-4 dark:hidden" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.66-5.66 1.41-1.41M4.93 19.07l1.41-1.41m0-11.32L4.93 4.93m14.14 14.14-1.41-1.41M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
          />
        </svg>
        <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M20.3 14.4A7.8 7.8 0 0 1 9.6 3.7 8.8 8.8 0 1 0 20.3 14.4Z"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
          />
        </svg>
      </button>

      <a class={actionClass} href="https://github.com/asJEI" target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.5v-1.9c-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.93.85.09-.66.35-1.12.64-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.92c.85 0 1.7.12 2.5.35 1.9-1.33 2.74-1.05 2.74-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.8-4.57 5.06.36.32.68.95.68 1.92v2.8c0 .28.18.6.69.5A10.17 10.17 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"
            fill="currentColor"
          />
        </svg>
      </a>
    </div>
  </nav>

  <div
    class="pointer-events-none mx-auto mt-3 hidden w-full max-w-2xl opacity-0 transition duration-200 data-[open=true]:pointer-events-auto data-[open=true]:grid data-[open=true]:opacity-100"
    data-search-panel
  >
    <div class="rounded-[1.25rem] border border-white/12 bg-slate-950/80 p-3 shadow-[0_18px_48px_rgb(0_0_0_/_0.24)] backdrop-blur-2xl">
      <label class="sr-only" for="site-search-input">搜索文章</label>
      <input
        id="site-search-input"
        class="h-11 w-full rounded-card border border-white/12 bg-white/8 px-4 text-sm text-white outline-none transition duration-200 placeholder:text-white/45 focus:border-accent/50 focus:bg-white/12"
        type="search"
        placeholder="搜索标题、摘要或标签..."
        autocomplete="off"
        data-search-input
      />
      <div class="mt-3 grid max-h-[22rem] gap-2 overflow-y-auto scrollbar-thin" data-search-results>
        <p class="m-0 px-2 py-3 text-sm text-white/58">输入关键词开始搜索。</p>
      </div>
    </div>
  </div>
</header>

<script define:vars={{ searchPosts }}>
  const toggle = document.querySelector("[data-theme-toggle]");
  const root = document.documentElement;
  const storedTheme = localStorage.getItem("theme");
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

  if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
    root.classList.add("dark");
  }

  toggle?.addEventListener("click", () => {
    const isDark = root.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });

  const searchToggle = document.querySelector("[data-search-toggle]");
  const searchPanel = document.querySelector("[data-search-panel]");
  const searchInput = document.querySelector("[data-search-input]");
  const searchResults = document.querySelector("[data-search-results]");

  const escapeHtml = (value) =>
    value.replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" })[char]);

  const renderSearchResults = (query) => {
    if (!searchResults) return;

    const keyword = query.trim().toLowerCase();

    if (!keyword) {
      searchResults.innerHTML = '<p class="m-0 px-2 py-3 text-sm text-white/58">输入关键词开始搜索。</p>';
      return;
    }

    const results = searchPosts
      .filter((post) => {
        const haystack = [post.title, post.description, ...post.tags].join(" ").toLowerCase();
        return haystack.includes(keyword);
      })
      .slice(0, 8);

    if (results.length === 0) {
      searchResults.innerHTML = '<p class="m-0 px-2 py-3 text-sm text-white/58">没有找到相关文章。</p>';
      return;
    }

    searchResults.innerHTML = results
      .map(
        (post) => `
          <a class="grid gap-1 rounded-card px-3 py-2 text-white/82 no-underline transition duration-200 hover:bg-white/10 hover:text-white" href="${post.href}">
            <span class="text-sm font-semibold leading-6">${escapeHtml(post.title)}</span>
            <span class="line-clamp-2 text-xs leading-5 text-white/55">${escapeHtml(post.description || post.tags.map((tag) => `#${tag}`).join(" "))}</span>
          </a>
        `,
      )
      .join("");
  };

  searchToggle?.addEventListener("click", () => {
    const isOpen = searchPanel?.getAttribute("data-open") === "true";
    searchPanel?.setAttribute("data-open", String(!isOpen));

    if (!isOpen) {
      requestAnimationFrame(() => searchInput?.focus());
    }
  });

  searchInput?.addEventListener("input", (event) => {
    renderSearchResults(event.currentTarget.value);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      searchPanel?.setAttribute("data-open", "false");
    }
  });
</script>
